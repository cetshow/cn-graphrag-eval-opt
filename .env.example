# LLM provider used by optional model-backed generation and evaluation.
LLM_PROVIDER=mimo
LLM_API_PROTOCOL=openai

# Use the exact Token Plan Base URL shown on your MiMo subscription page.
# Examples:
# - https://token-plan-cn.xiaomimimo.com/v1
# - https://token-plan-sgp.xiaomimimo.com/v1
# - https://token-plan-ams.xiaomimimo.com/v1
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_KEY=replace-with-your-dedicated-api-key
LLM_MODEL=mimo-v2.5-pro

# Generation defaults. Tune these per benchmark or production scenario.
LLM_TEMPERATURE=0.2
LLM_TOP_P=1.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_COUNT=2
LLM_AUTH_HEADER=api-key

# Optional Anthropic-compatible endpoint from the same plan.
ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
